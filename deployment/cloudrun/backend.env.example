# Non-secret runtime variables for Cloud Run service
API_BASE_URL=https://your-cloud-run-service-url
FRONTEND_URL=https://your-frontend.vercel.app
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://your-custom-domain

# Optional
QDRANT_COLLECTION=rfp_chunks
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Store these in GCP Secret Manager and map via deployment/cloudrun/configure_runtime.sh:
# QDRANT_URL
# QDRANT_API_KEY
# SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY
# OPENAI_API_KEY
# GOOGLE_CLIENT_ID
# GOOGLE_CLIENT_SECRET
# LLAMA_PARSE_KEY
